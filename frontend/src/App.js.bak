// ─── Page Analyse Vidéo ──────────────────────────────────────────────────────
const PageAnalyse = () => {
  const [dragging, setDragging]     = useState(false);
  const [file, setFile]             = useState(null);
  const [loading, setLoading]       = useState(false);
  const [result, setResult]         = useState(null);
  const [error, setError]           = useState(null);

  const handleFile = (f) => {
    if (!f) return;
    const ok = ["video/mp4", "video/avi", "video/quicktime"].includes(f.type) ||
               f.name.match(/\.(mp4|avi|mov)$/i);
    if (!ok) { setError("Format non supporté. Utilisez .mp4, .avi ou .mov"); return; }
    setFile(f); setError(null); setResult(null);
  };

  const analyze = async () => {
    if (!file) return;
    setLoading(true); setError(null);
    const form = new FormData();
    form.append("video", file);
    try {
      const res = await fetch("http://localhost:5000/api/analyze-video", { method: "POST", body: form });
      if (!res.ok) throw new Error(`Erreur serveur ${res.status}`);
      const data = await res.json();
      setResult(data);
    } catch (e) {
      setError(e.message.includes("fetch") ? "API Flask inaccessible — lancez `python api.py`" : e.message);
    } finally {
      setLoading(false);
    }
  };

  const mockDemo = () => {
    setResult({
      score: 42,
      niveau: "attention",
      r_moyen: 30.52,
      rapport: "Légère asymétrie détectée à la hanche gauche. Vitesse angulaire cheville dans les normes. GRF symétrique.",
      angles_temporels: Array.from({ length: 40 }, (_, i) => ({
        t: i,
        hanche_g: 15 + 20 * Math.sin(i * 0.3) + Math.random() * 3,
        genou_g:  30 + 25 * Math.sin(i * 0.3 + 1) + Math.random() * 3,
        cheville_g: 10 + 12 * Math.sin(i * 0.3 + 2) + Math.random() * 3,
      })),
      r_temporel: Array.from({ length: 40 }, (_, i) => ({
        t: i, r: 30 + 1.5 * Math.sin(i * 0.4) + Math.random() * 0.8,
      })),
    });
  };

  return (
    <div>
      <SectionTitle>🎥 Analyse Vidéo — Pipeline MediaPipe</SectionTitle>

      {/* Upload zone */}
      <div
        onDragOver={e => { e.preventDefault(); setDragging(true); }}
        onDragLeave={() => setDragging(false)}
        onDrop={e => { e.preventDefault(); setDragging(false); handleFile(e.dataTransfer.files[0]); }}
        onClick={() => document.getElementById("fileInput").click()}
        style={{
          border: `2px dashed ${dragging ? C.accent : C.border}`,
          borderRadius: 12, padding: "40px 24px", textAlign: "center",
          cursor: "pointer", transition: "border-color .2s",
          background: dragging ? "rgba(59,130,246,0.05)" : C.card,
          marginBottom: 20,
        }}
      >
        <input id="fileInput" type="file" accept=".mp4,.avi,.mov" hidden
          onChange={e => handleFile(e.target.files[0])} />
        <div style={{ fontSize: 36, marginBottom: 12 }}>📹</div>
        {file
          ? <div style={{ color: C.textPri, fontWeight: 600 }}>✅ {file.name}</div>
          : <div style={{ color: C.textSec }}>Glissez une vidéo ici ou cliquez pour sélectionner<br />
              <span style={{ fontSize: 12, color: C.textMut }}>Formats : .mp4, .avi, .mov</span>
            </div>
        }
      </div>

      {error && <div style={{
        background: "#7F1D1D33", border: `1px solid ${C.red}44`,
        color: C.red, padding: "12px 16px", borderRadius: 8, marginBottom: 16, fontSize: 14,
      }}>⚠ {error}</div>}

      <div style={{ display: "flex", gap: 12, marginBottom: 28 }}>
        <button onClick={analyze} disabled={!file || loading} style={{
          background: C.accent, color: "#fff", border: "none", borderRadius: 8,
          padding: "12px 24px", fontWeight: 700, cursor: file && !loading ? "pointer" : "not-allowed",
          opacity: file && !loading ? 1 : 0.5, fontSize: 14,
        }}>{loading ? "Analyse en cours…" : "Analyser la vidéo"}</button>
        <button onClick={mockDemo} style={{
          background: C.card, color: C.textSec, border: `1px solid ${C.border}`,
          borderRadius: 8, padding: "12px 24px", fontWeight: 600, cursor: "pointer", fontSize: 14,
        }}>🔬 Démo simulée</button>
      </div>

      {loading && (
        <div style={{ textAlign: "center", padding: 40 }}>
          <div style={{ color: C.accent, fontSize: 14, marginBottom: 12 }}>
            Extraction MediaPipe → calcul angles → inférence R(s,a)…
          </div>
          <div style={{
            height: 4, background: C.border, borderRadius: 2, overflow: "hidden",
          }}>
            <div style={{
              height: "100%", background: C.accent, width: "60%",
              animation: "none", borderRadius: 2,
            }} />
          </div>
        </div>
      )}

      {result && (
        <div>
          <div style={{ display: "grid", gridTemplateColumns: "auto 1fr", gap: 20, marginBottom: 24 }}>
            <div style={{
              background: C.card, border: `1px solid ${C.border}`,
              borderRadius: 12, padding: 24, textAlign: "center",
            }}>
              <ScoreGauge score={result.score} />
              <div style={{ marginTop: 10 }}>
                <Badge niveau={result.niveau} />
              </div>
              <div style={{ color: C.textMut, fontSize: 12, marginTop: 8 }}>
                R̄(s,a) = {result.r_moyen?.toFixed(2)}
              </div>
            </div>
            <div style={{
              background: C.card, border: `1px solid ${C.border}`,
              borderRadius: 12, padding: 24,
            }}>
              <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
                letterSpacing: 1, textTransform: "uppercase", marginBottom: 12 }}>Rapport automatique</div>
              <p style={{ color: C.textPri, lineHeight: 1.7, fontSize: 14, margin: 0 }}>
                {result.rapport}
              </p>
              <div style={{ marginTop: 16, padding: "10px 14px",
                background: "rgba(59,130,246,0.08)", borderRadius: 8, fontSize: 12, color: C.textSec }}>
                ⚠ Score calculé sur angles + vitesses uniquement (couples non disponibles depuis vidéo). Résultat indicatif.
              </div>
            </div>
          </div>

          {result.angles_temporels && (
            <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24, marginBottom: 20 }}>
              <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
                letterSpacing: 1, textTransform: "uppercase", marginBottom: 16 }}>Angles articulaires (°)</div>
              <ResponsiveContainer width="100%" height={200}>
                <LineChart data={result.angles_temporels}>
                  <CartesianGrid stroke={C.border} strokeDasharray="3 3" />
                  <XAxis dataKey="t" stroke={C.textMut} tick={{ fontSize: 11 }} label={{ value: "Frame", position: "insideBottom", fill: C.textMut, fontSize: 11, dy: 6 }} />
                  <YAxis stroke={C.textMut} tick={{ fontSize: 11 }} />
                  <Tooltip contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8 }} labelStyle={{ color: C.textSec }} />
                  <Legend wrapperStyle={{ fontSize: 12 }} />
                  <Line type="monotone" dataKey="hanche_g" stroke={C.accent} dot={false} name="Hanche G" strokeWidth={2} />
                  <Line type="monotone" dataKey="genou_g" stroke={C.teal} dot={false} name="Genou G" strokeWidth={2} />
                  <Line type="monotone" dataKey="cheville_g" stroke={C.green} dot={false} name="Cheville G" strokeWidth={2} />
                </LineChart>
              </ResponsiveContainer>
            </div>
          )}

          {result.r_temporel && (
            <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24 }}>
              <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
                letterSpacing: 1, textTransform: "uppercase", marginBottom: 16 }}>R(s,a) temporelle</div>
              <ResponsiveContainer width="100%" height={160}>
                <AreaChart data={result.r_temporel}>
                  <defs>
                    <linearGradient id="gR" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="5%" stopColor={C.accent} stopOpacity={0.3} />
                      <stop offset="95%" stopColor={C.accent} stopOpacity={0} />
                    </linearGradient>
                  </defs>
                  <CartesianGrid stroke={C.border} strokeDasharray="3 3" />
                  <XAxis dataKey="t" stroke={C.textMut} tick={{ fontSize: 11 }} />
                  <YAxis stroke={C.textMut} tick={{ fontSize: 11 }} domain={["auto", "auto"]} />
                  <Tooltip contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8 }} labelStyle={{ color: C.textSec }} />
                  <Area type="monotone" dataKey="r" stroke={C.accent} fill="url(#gR)" strokeWidth={2} dot={false} name="R(s,a)" />
                </AreaChart>
              </ResponsiveContainer>
            </div>
          )}
        </div>
      )}
    </div>
  );
};

// ─── Page Participants ───────────────────────────────────────────────────────
const PageParticipants = () => {
  const [selected, setSelected] = useState(null);

  const p = selected ? PARTICIPANTS.find(x => x.id === selected) : null;

  return (
    <div>
      <SectionTitle>👥 Participants — Leave-One-Out</SectionTitle>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))", gap: 14, marginBottom: 28 }}>
        {PARTICIPANTS.map(pt => (
          <div key={pt.id} onClick={() => setSelected(selected === pt.id ? null : pt.id)} style={{
            background: selected === pt.id ? `${C.accent}18` : C.card,
            border: `1px solid ${selected === pt.id ? C.accent : C.border}`,
            borderRadius: 12, padding: "18px 20px", cursor: "pointer",
            transition: "all .2s",
          }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 12 }}>
              <span style={{ color: C.textPri, fontWeight: 800, fontSize: 18 }}>{pt.id}</span>
              <Badge niveau={pt.niveau} />
            </div>
            <div style={{ display: "flex", justifyContent: "space-between" }}>
              <div>
                <div style={{ color: C.textMut, fontSize: 11, marginBottom: 3 }}>Score</div>
                <div style={{ color: C.textPri, fontWeight: 700, fontSize: 20, fontFamily: "monospace" }}>
                  {pt.score.toFixed(1)}
                </div>
              </div>
              <div>
                <div style={{ color: C.textMut, fontSize: 11, marginBottom: 3 }}>R̄(s,a)</div>
                <div style={{ color: C.accent, fontWeight: 700, fontSize: 16, fontFamily: "monospace" }}>
                  {pt.r_moy.toFixed(2)}
                </div>
              </div>
              <div>
                <div style={{ color: C.textMut, fontSize: 11, marginBottom: 3 }}>Cond.</div>
                <div style={{ color: C.textSec, fontWeight: 700, fontSize: 16 }}>
                  {pt.conditions}
                </div>
              </div>
            </div>
            <div style={{ marginTop: 10, height: 4, background: C.border, borderRadius: 2, overflow: "hidden" }}>
              <div style={{
                height: "100%", borderRadius: 2,
                background: pt.score > 75 ? C.green : pt.score > 25 ? C.amber : C.red,
                width: `${pt.score}%`, transition: "width .4s",
              }} />
            </div>
          </div>
        ))}
      </div>

      {p && (
        <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 28, marginBottom: 28 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 20, marginBottom: 20 }}>
            <ScoreGauge score={p.score} />
            <div>
              <h3 style={{ color: C.textPri, fontWeight: 800, fontSize: 24, marginBottom: 6 }}>{p.id}</h3>
              <Badge niveau={p.niveau} />
              <div style={{ marginTop: 10, display: "grid", gridTemplateColumns: "1fr 1fr", gap: "8px 24px" }}>
                {[
                  ["R̄(s,a)", p.r_moy.toFixed(2)],
                  ["z-score", (p.z >= 0 ? "+" : "") + p.z.toFixed(3)],
                  ["Score percentile", p.score.toFixed(1)],
                  ["Conditions", p.conditions],
                ].map(([k, v]) => (
                  <div key={k}>
                    <span style={{ color: C.textMut, fontSize: 12 }}>{k} : </span>
                    <span style={{ color: C.textPri, fontWeight: 700, fontFamily: "monospace", fontSize: 13 }}>{v}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div style={{ fontSize: 13, color: C.textSec, padding: "12px 16px",
            background: "rgba(59,130,246,0.07)", borderRadius: 8 }}>
            z-score &lt; 0.25 → Ce participant est homogène avec les autres sujets sains.
            Sur une population plus large et diverse, le score discriminerait davantage.
          </div>
        </div>
      )}

      {/* Bar chart comparaison */}
      <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24 }}>
        <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
          letterSpacing: 1, textTransform: "uppercase", marginBottom: 16 }}>Comparaison R̄(s,a) par participant</div>
        <ResponsiveContainer width="100%" height={220}>
          <BarChart data={PARTICIPANTS} barSize={32}>
            <CartesianGrid stroke={C.border} strokeDasharray="3 3" />
            <XAxis dataKey="id" stroke={C.textMut} tick={{ fontSize: 12, fill: C.textSec }} />
            <YAxis stroke={C.textMut} tick={{ fontSize: 11, fill: C.textSec }} domain={[30.2, 31.0]} />
            <Tooltip
              contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8, color: C.textPri }}
              formatter={(v) => [v.toFixed(3), "R̄(s,a)"]}
            />
            <ReferenceLine y={30.58} stroke={C.textMut} strokeDasharray="4 4" label={{ value: "μ", fill: C.textMut, fontSize: 11 }} />
            <Bar dataKey="r_moy" radius={[4, 4, 0, 0]}
              fill={C.accent}
              label={{ position: "top", fill: C.textMut, fontSize: 10, formatter: v => v.toFixed(2) }}
            />
          </BarChart>
        </ResponsiveContainer>
      </div>
    </div>
  );
};

// ─── Page Référence ──────────────────────────────────────────────────────────
const PageReference = () => (
  <div>
    <SectionTitle>📈 Modèle de Référence</SectionTitle>

    <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(190px, 1fr))", gap: 16, marginBottom: 28 }}>
      <StatCard label="Moyenne R(s,a)" value="30.58" sub="± 1.01 (faible variance)" accent={C.accent} />
      <StatCard label="Vitesse optimale" value="1.2 m/s" sub="Polynôme deg.2 → 1.42 m/s" accent={C.teal} />
      <StatCard label="R² ajustement" value="0.479" sub="Courbe en U inversé ✓" accent={C.green} />
      <StatCard label="Trajectoires" value="251" sub="9 sujets × ~28 conditions" accent="#A78BFA" />
    </div>

    {/* Distribution de référence */}
    <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24, marginBottom: 20 }}>
      <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
        letterSpacing: 1, textTransform: "uppercase", marginBottom: 4 }}>Distribution R(s,a) — Population de référence</div>
      <div style={{ color: C.textMut, fontSize: 12, marginBottom: 16 }}>
        P5 = 29.27 &nbsp;·&nbsp; P25 = 30.38 &nbsp;·&nbsp; P50 = 30.75 &nbsp;·&nbsp; P75 = 31.02 &nbsp;·&nbsp; P95 = 31.50
      </div>
      <ResponsiveContainer width="100%" height={200}>
        <AreaChart data={DIST_REF}>
          <defs>
            <linearGradient id="gDist" x1="0" y1="0" x2="0" y2="1">
              <stop offset="5%" stopColor={C.accent} stopOpacity={0.35} />
              <stop offset="95%" stopColor={C.accent} stopOpacity={0.0} />
            </linearGradient>
          </defs>
          <CartesianGrid stroke={C.border} strokeDasharray="3 3" />
          <XAxis dataKey="x" stroke={C.textMut} tick={{ fontSize: 10, fill: C.textSec }}
            label={{ value: "R(s,a)", position: "insideBottom", fill: C.textMut, dy: 6, fontSize: 11 }} />
          <YAxis stroke={C.textMut} tick={{ fontSize: 10, fill: C.textSec }} />
          <Tooltip contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8 }}
            formatter={(v) => [v.toFixed(4), "Densité"]} />
          <ReferenceLine x="30.38" stroke={C.amber} strokeDasharray="3 3" label={{ value: "P25", fill: C.amber, fontSize: 10 }} />
          <ReferenceLine x="31.02" stroke={C.amber} strokeDasharray="3 3" label={{ value: "P75", fill: C.amber, fontSize: 10 }} />
          <Area type="monotone" dataKey="y" stroke={C.accent} fill="url(#gDist)" strokeWidth={2} dot={false} />
        </AreaChart>
      </ResponsiveContainer>
    </div>

    {/* Vitesse optimale */}
    <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24, marginBottom: 20 }}>
      <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
        letterSpacing: 1, textTransform: "uppercase", marginBottom: 4 }}>R(s,a) vs Vitesse de marche — Courbe en U inversé</div>
      <div style={{ color: C.textMut, fontSize: 12, marginBottom: 16 }}>
        Le modèle a découvert spontanément que la vitesse optimale est 1.2–1.4 m/s, sans supervision explicite.
      </div>
      <ResponsiveContainer width="100%" height={200}>
        <LineChart data={VITESSE_DATA}>
          <CartesianGrid stroke={C.border} strokeDasharray="3 3" />
          <XAxis dataKey="v" stroke={C.textMut} tick={{ fontSize: 11, fill: C.textSec }}
            label={{ value: "Vitesse (m/s)", position: "insideBottom", fill: C.textMut, dy: 6, fontSize: 11 }} />
          <YAxis stroke={C.textMut} tick={{ fontSize: 11, fill: C.textSec }} domain={[29.0, 31.0]} />
          <Tooltip contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8 }}
            formatter={(v) => [v.toFixed(2), "R̄(s,a)"]} />
          <ReferenceLine x="1.2" stroke={C.green} strokeDasharray="4 4" label={{ value: "Optimal", fill: C.green, fontSize: 11 }} />
          <Line type="monotone" dataKey="r" stroke={C.teal} strokeWidth={2.5} dot={{ fill: C.teal, r: 4 }} name="R̄(s,a)" />
        </LineChart>
      </ResponsiveContainer>
    </div>

    {/* Importance */}
    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}>
      <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24 }}>
        <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
          letterSpacing: 1, textTransform: "uppercase", marginBottom: 16 }}>Importance par articulation</div>
        <ResponsiveContainer width="100%" height={200}>
          <PieChart>
            <Pie data={ARTICULAIRE_DATA} dataKey="pct" nameKey="name" cx="50%" cy="50%" outerRadius={80} label={({ name, pct }) => `${name} ${pct}%`} labelLine={false}>
              {ARTICULAIRE_DATA.map((d, i) => <Cell key={i} fill={d.color} />)}
            </Pie>
            <Tooltip contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8 }}
              formatter={(v) => [`${v}%`, "Contribution"]} />
          </PieChart>
        </ResponsiveContainer>
      </div>

      <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 24 }}>
        <div style={{ color: C.textSec, fontSize: 12, fontWeight: 700,
          letterSpacing: 1, textTransform: "uppercase", marginBottom: 16 }}>Importance par groupe de features</div>
        <ResponsiveContainer width="100%" height={200}>
          <BarChart data={IMPORTANCE_DATA} layout="vertical" barSize={12}>
            <CartesianGrid stroke={C.border} strokeDasharray="3 3" horizontal={false} />
            <XAxis type="number" stroke={C.textMut} tick={{ fontSize: 10, fill: C.textSec }} domain={[0, 20]} />
            <YAxis type="category" dataKey="name" stroke={C.textMut} tick={{ fontSize: 10, fill: C.textSec }} width={100} />
            <Tooltip contentStyle={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8 }}
              formatter={(v) => [`${v}%`, "Importance"]} />
            <Bar dataKey="pct" radius={[0, 4, 4, 0]}>
              {IMPORTANCE_DATA.map((d, i) => <Cell key={i} fill={d.color} />)}
            </Bar>
          </BarChart>
        </ResponsiveContainer>
        <div style={{ marginTop: 14, fontSize: 12, color: C.textMut, lineHeight: 1.6 }}>
          Méthode : <span style={{ color: C.textSec, fontFamily: "monospace" }}>importance(i) = |∂R/∂xᵢ| × |xᵢ|</span>
          <br />moyenné sur 18 000 frames équilibrées (2 000 / participant)
        </div>
      </div>
    </div>
  </div>
);

// ─── Main App ────────────────────────────────────────────────────────────────
const PAGES = [
  { id: "accueil",      label: "🏠 Accueil",       component: PageAccueil },
  { id: "analyse",      label: "📊 Analyse vidéo", component: PageAnalyse },
  { id: "participants", label: "👥 Participants",   component: PageParticipants },
  { id: "reference",    label: "📈 Référence",      component: PageReference },
];

export default function App() {
  const [page, setPage] = useState("accueil");
  const ActivePage = PAGES.find(p => p.id === page)?.component || PageAccueil;

  return (
    <div style={{
      minHeight: "100vh", background: C.bg, color: C.textPri,
      fontFamily: "'Inter', 'Segoe UI', system-ui, sans-serif",
    }}>
      {/* Nav */}
      <nav style={{
        background: C.surface, borderBottom: `1px solid ${C.border}`,
        position: "sticky", top: 0, zIndex: 100,
      }}>
        <div style={{
          maxWidth: 1200, margin: "0 auto", padding: "0 24px",
          display: "flex", alignItems: "center", height: 56, gap: 8,
        }}>
          <div style={{ color: C.accent, fontWeight: 900, fontSize: 16, marginRight: 24, letterSpacing: -0.5 }}>
            IRL<span style={{ color: C.textSec }}>·Bio</span>
          </div>
          {PAGES.map(p => (
            <button key={p.id} onClick={() => setPage(p.id)} style={{
              background: page === p.id ? `${C.accent}18` : "transparent",
              color: page === p.id ? C.accent : C.textSec,
              border: page === p.id ? `1px solid ${C.accent}44` : "1px solid transparent",
              borderRadius: 8, padding: "6px 14px", cursor: "pointer",
              fontWeight: page === p.id ? 700 : 500, fontSize: 13,
              transition: "all .15s",
            }}>{p.label}</button>
          ))}
          <div style={{ marginLeft: "auto", display: "flex", alignItems: "center", gap: 8 }}>
            <div style={{ width: 8, height: 8, borderRadius: "50%", background: C.green }} />
            <span style={{ color: C.textMut, fontSize: 12 }}>Amina & Imane</span>
          </div>
        </div>
      </nav>

      {/* Content */}
      <main style={{ maxWidth: 1200, margin: "0 auto", padding: "32px 24px" }}>
        <ActivePage />
      </main>

      {/* Footer */}
      <footer style={{
        borderTop: `1px solid ${C.border}`, padding: "20px 24px",
        textAlign: "center", color: C.textMut, fontSize: 12,
      }}>
        IRL Biomécanique · Amina & Imane ·{" "}
        <a href="https://figshare.com/articles/dataset/16530939" target="_blank" rel="noreferrer"
          style={{ color: C.accent, textDecoration: "none" }}>Dataset Figshare</a>
      </footer>
    </div>
  );
}
