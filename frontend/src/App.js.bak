  { name: "GRF",    pct: 16.4, color: "#A78BFA" },
];

const DIST_REF = Array.from({ length: 40 }, (_, i) => {
  const x = 28.5 + i * 0.075;
  const mu = 30.58, sigma = 1.01;
  const y = Math.exp(-0.5 * ((x - mu) / sigma) ** 2) / (sigma * Math.sqrt(2 * Math.PI));
  return { x: x.toFixed(2), y: parseFloat(y.toFixed(4)) };
});

// ─── Shared components ───────────────────────────────────────────────────────
const Badge = ({ niveau }) => {
  const cfg = {
    normal:    { label: "✓ Normale",  bg: "#064E3B", text: C.green },
    attention: { label: "⚠ Attention", bg: "#78350F", text: C.amber },
    ecart:     { label: "✕ Écart",    bg: "#7F1D1D", text: C.red   },
  }[niveau] || { label: niveau, bg: C.border, text: C.textSec };
  return (
    <span style={{
      background: cfg.bg, color: cfg.text,
      padding: "2px 10px", borderRadius: 99,
      fontSize: 12, fontWeight: 700, letterSpacing: 0.5,
    }}>{cfg.label}</span>
  );
};

const StatCard = ({ label, value, sub, accent }) => (
  <div style={{
    background: C.card, border: `1px solid ${C.border}`,
    borderRadius: 12, padding: "20px 24px",
    borderLeft: `3px solid ${accent || C.accent}`,
  }}>
    <div style={{ color: C.textSec, fontSize: 12, fontWeight: 600,
      letterSpacing: 1, textTransform: "uppercase", marginBottom: 6 }}>{label}</div>
    <div style={{ color: C.textPri, fontSize: 28, fontWeight: 800,
      fontFamily: "monospace", lineHeight: 1 }}>{value}</div>
    {sub && <div style={{ color: C.textMut, fontSize: 12, marginTop: 6 }}>{sub}</div>}
  </div>
);

const SectionTitle = ({ children }) => (
  <h2 style={{
    color: C.textPri, fontSize: 18, fontWeight: 700,
    marginBottom: 20, display: "flex", alignItems: "center", gap: 10,
  }}>{children}</h2>
);

// ─── Circular gauge ──────────────────────────────────────────────────────────
const ScoreGauge = ({ score }) => {
  const r = 54, cx = 64, cy = 64;
  const circ = 2 * Math.PI * r;
  const dash = (score / 100) * circ;
  const color = score > 75 ? C.green : score > 25 ? C.amber : C.red;
  const label = score > 75 ? "Optimale" : score > 25 ? "Normale" : "Écart";
  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 8 }}>
      <svg width={128} height={128} viewBox="0 0 128 128">
        <circle cx={cx} cy={cy} r={r} fill="none" stroke={C.border} strokeWidth={10} />
        <circle cx={cx} cy={cy} r={r} fill="none" stroke={color} strokeWidth={10}
          strokeDasharray={`${dash} ${circ}`}
          strokeLinecap="round" transform="rotate(-90 64 64)" />
        <text x={cx} y={cy - 6} textAnchor="middle" fill={C.textPri}
          fontSize={22} fontWeight={800} fontFamily="monospace">{score.toFixed(0)}</text>
        <text x={cx} y={cy + 14} textAnchor="middle" fill={C.textSec} fontSize={11}>{label}</text>
      </svg>
    </div>
  );
};

// ─── Page Accueil ────────────────────────────────────────────────────────────
