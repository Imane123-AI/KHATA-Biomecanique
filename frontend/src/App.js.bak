          }}>{t}</span>
        ))}
      </div>
    </div>

    {/* Stats */}
    <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(190px, 1fr))", gap: 16, marginBottom: 32 }}>
      <StatCard label="R_expert / R_random" value="×3.07" sub="Modèle distingue expert vs aléatoire" accent={C.accent} />
      <StatCard label="Vitesse optimale" value="1.2 m/s" sub="Découverte spontanée par le modèle" accent={C.teal} />
      <StatCard label="Articulation dominante" value="Hanche" sub="32.5% — hiérarchie biomécanique confirmée" accent={C.green} />
      <StatCard label="Loss finale" value="-6.10" sub="Convergence sur 150 epochs" accent="#A78BFA" />
    </div>

    {/* Pipeline */}
    <div style={{ background: C.card, border: `1px solid ${C.border}`, borderRadius: 12, padding: 28, marginBottom: 32 }}>
      <SectionTitle>Pipeline IRL</SectionTitle>
      <div style={{ display: "flex", alignItems: "center", gap: 0, flexWrap: "wrap" }}>
        {[
          { step: "01", label: "Extraction", desc: "42 états + 18 actions", color: C.accent },
          { step: "02", label: "Nettoyage", desc: "Butterworth 6Hz", color: C.teal },
          { step: "03", label: "MaxEnt IRL", desc: "RewardNetwork 60→1", color: C.green },
          { step: "04", label: "Analyse", desc: "Vitesse, importance", color: "#A78BFA" },
          { step: "05", label: "Score", desc: "Percentile 0–100", color: C.amber },
        ].map((s, i) => (
          <div key={s.step} style={{ display: "flex", alignItems: "center" }}>
            <div style={{ textAlign: "center", padding: "0 8px" }}>
              <div style={{
                width: 48, height: 48, borderRadius: "50%",
                background: `${s.color}22`, border: `2px solid ${s.color}`,
                display: "flex", alignItems: "center", justifyContent: "center",
                color: s.color, fontWeight: 800, fontSize: 13, margin: "0 auto 8px",
              }}>{s.step}</div>
              <div style={{ color: C.textPri, fontWeight: 700, fontSize: 13 }}>{s.label}</div>
              <div style={{ color: C.textMut, fontSize: 11, marginTop: 3 }}>{s.desc}</div>
